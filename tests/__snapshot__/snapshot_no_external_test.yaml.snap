should create configmap and volume inside frontend:
  1: |
    apiVersion: v1
    data:
      config.json: |-
        {
          "backendUrl": "http://operator-node-port:30123"
        }
    kind: ConfigMap
    metadata:
      labels:
        app.kubernetes.io/component: frontend
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: trivy-operator-web-ui
        app.kubernetes.io/version: x.y.z
        helm.sh/chart: trivy-operator-web-ui
      name: trivy-operator-web-ui-frontend
  2: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/component: frontend
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: trivy-operator-web-ui
        app.kubernetes.io/version: x.y.z
        helm.sh/chart: trivy-operator-web-ui
      name: trivy-operator-web-ui-frontend
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/component: frontend
          app.kubernetes.io/instance: RELEASE-NAME
          app.kubernetes.io/name: trivy-operator-web-ui
          app.kubernetes.io/version: x.y.z
      template:
        metadata:
          annotations:
            annotations.pod.operator: "true"
          labels:
            app.kubernetes.io/component: frontend
            app.kubernetes.io/instance: RELEASE-NAME
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: trivy-operator-web-ui
            app.kubernetes.io/version: x.y.z
            helm.sh/chart: trivy-operator-web-ui
            labels.pod.operator: "true"
        spec:
          affinity:
            nodeAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
                nodeSelectorTerms:
                  - matchExpressions:
                      - key: topology.kubernetes.io/frontend
                        operator: In
                        values:
                          - frontend-east1
                          - frontend-west1
          containers:
            - image: ghcr.io/trivy-operator-web-ui/frontend:1.0.0-frontend
              imagePullPolicy: IfNotPresent
              livenessProbe:
                httpGet:
                  path: /
                  port: http
              name: trivy-operator-web-ui-operator
              ports:
                - containerPort: 8080
                  name: http
                  protocol: TCP
              readinessProbe:
                httpGet:
                  path: /
                  port: http
              resources:
                limits:
                  memory: 100Mi
                requests:
                  cpu: 10m
              securityContext:
                capabilities:
                  drop:
                    - ALL
                runAsNonRoot: true
                runAsUser: 101
              volumeMounts:
                - mountPath: /usr/share/nginx/html/assets/config.json
                  name: config-volume
                  subPath: config.json
          nodeSelector:
            disktype: ssdFrontend
          serviceAccountName: trivy-operator-web-ui-frontend
          tolerations:
            - effect: NoExecute
              key: node.kubernetes.io/frontend
              operator: Exists
              tolerationSeconds: 6000
          volumes:
            - configMap:
                name: trivy-operator-web-ui-frontend
              name: config-volume
  3: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app.kubernetes.io/component: frontend
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: trivy-operator-web-ui
        app.kubernetes.io/version: x.y.z
        helm.sh/chart: trivy-operator-web-ui
      name: trivy-operator-web-ui-frontend
    spec:
      ports:
        - name: http
          port: 8080
          protocol: TCP
          targetPort: http
      selector:
        app.kubernetes.io/component: frontend
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/name: trivy-operator-web-ui
        app.kubernetes.io/version: x.y.z
      type: ClusterIP
  4: |
    apiVersion: v1
    automountServiceAccountToken: true
    kind: ServiceAccount
    metadata:
      annotations:
        annotations.serviceaccount.frontend: "true"
      labels:
        app.kubernetes.io/component: frontend
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: trivy-operator-web-ui
        app.kubernetes.io/version: x.y.z
        helm.sh/chart: trivy-operator-web-ui
      name: trivy-operator-web-ui-frontend
  5: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    metadata:
      labels:
        app.kubernetes.io/component: operator
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: trivy-operator-web-ui
        app.kubernetes.io/version: x.y.z
        helm.sh/chart: trivy-operator-web-ui
      name: trivy-operator-web-ui-operator
    rules:
      - apiGroups:
          - aquasecurity.github.io
        resources:
          - vulnerabilityreports
          - sbomreports
          - exposedsecretreports
        verbs:
          - get
          - watch
          - list
