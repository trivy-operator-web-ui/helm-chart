manifest should match snapshot:
  1: |
    apiVersion: gateway.networking.k8s.io/v1
    kind: HTTPRoute
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: trivy-operator-web-ui
        helm.sh/chart: trivy-operator-web-ui
      name: trivy-operator-web-ui
    spec:
      hostnames:
        - host-1.com
        - host-2.com
      parentRefs:
        - name: gateway
          sectionName: http
      rules:
        - backendRefs:
            - name: trivy-operator-web-ui-frontend
              port: 8080
              weight: 1
          filters:
            - requestHeaderModifier:
                remove:
                  - User-Agent
                set:
                  - name: My-Overwrite-Header-Frontend
                    value: this-is-the-only-value-frontend
              type: RequestHeaderModifier
          matches:
            - path:
                type: PathPrefix
                value: /
        - backendRefs:
            - name: trivy-operator-web-ui-operator
              port: 8080
              weight: 1
          filters:
            - requestHeaderModifier:
                remove:
                  - User-Agent
                set:
                  - name: My-Overwrite-Header-Operator
                    value: this-is-the-only-value-operator
              type: RequestHeaderModifier
          matches:
            - path:
                type: PathPrefix
                value: /api
  2: |
    apiVersion: networking.k8s.io/v1
    kind: Ingress
    metadata:
      annotations:
        kubernetes.io/tls-acme: "true"
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: trivy-operator-web-ui
        helm.sh/chart: trivy-operator-web-ui
      name: trivy-operator-web-ui
    spec:
      ingressClassName: classname
      rules:
        - host: host-1.com
          http:
            paths:
              - backend:
                  service:
                    name: trivy-operator-web-ui-frontend
                    port:
                      number: 8080
                path: /
                pathType: ImplementationSpecific
        - host: host-1.com
          http:
            paths:
              - backend:
                  service:
                    name: trivy-operator-web-ui-operator
                    port:
                      number: 8080
                path: /api
                pathType: ImplementationSpecific
        - host: host-2.com
          http:
            paths:
              - backend:
                  service:
                    name: trivy-operator-web-ui-frontend
                    port:
                      number: 8080
                path: /
                pathType: ImplementationSpecific
        - host: host-2.com
          http:
            paths:
              - backend:
                  service:
                    name: trivy-operator-web-ui-operator
                    port:
                      number: 8080
                path: /api
                pathType: ImplementationSpecific
      tls:
        - hosts:
            - host-1.com
          secretName: host-1
  3: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/component: frontend
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: trivy-operator-web-ui
        app.kubernetes.io/version: x.y.z
        helm.sh/chart: trivy-operator-web-ui
      name: trivy-operator-web-ui-frontend
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/component: frontend
          app.kubernetes.io/instance: RELEASE-NAME
          app.kubernetes.io/name: trivy-operator-web-ui
          app.kubernetes.io/version: x.y.z
      template:
        metadata:
          annotations:
            annotations.pod.operator: "true"
          labels:
            app.kubernetes.io/component: frontend
            app.kubernetes.io/instance: RELEASE-NAME
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: trivy-operator-web-ui
            app.kubernetes.io/version: x.y.z
            helm.sh/chart: trivy-operator-web-ui
            labels.pod.operator: "true"
        spec:
          affinity:
            nodeAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
                nodeSelectorTerms:
                  - matchExpressions:
                      - key: topology.kubernetes.io/frontend
                        operator: In
                        values:
                          - frontend-east1
                          - frontend-west1
          containers:
            - image: ghcr.io/trivy-operator-web-ui/frontend:1.0.0-frontend
              imagePullPolicy: IfNotPresent
              livenessProbe:
                httpGet:
                  path: /
                  port: http
              name: trivy-operator-web-ui-operator
              ports:
                - containerPort: 8080
                  name: http
                  protocol: TCP
              readinessProbe:
                httpGet:
                  path: /
                  port: http
              resources:
                limits:
                  memory: 100Mi
                requests:
                  cpu: 10m
              securityContext:
                capabilities:
                  drop:
                    - ALL
                runAsNonRoot: true
                runAsUser: 101
          nodeSelector:
            disktype: ssdFrontend
          serviceAccountName: trivy-operator-web-ui-frontend
          tolerations:
            - effect: NoExecute
              key: node.kubernetes.io/frontend
              operator: Exists
              tolerationSeconds: 6000
  4: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app.kubernetes.io/component: frontend
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: trivy-operator-web-ui
        app.kubernetes.io/version: x.y.z
        helm.sh/chart: trivy-operator-web-ui
      name: trivy-operator-web-ui-frontend
    spec:
      ports:
        - name: http
          port: 8080
          protocol: TCP
          targetPort: http
      selector:
        app.kubernetes.io/component: frontend
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/name: trivy-operator-web-ui
        app.kubernetes.io/version: x.y.z
      type: ClusterIP
  5: |
    apiVersion: v1
    automountServiceAccountToken: true
    kind: ServiceAccount
    metadata:
      annotations:
        annotations.serviceaccount.frontend: "true"
      labels:
        app.kubernetes.io/component: frontend
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: trivy-operator-web-ui
        app.kubernetes.io/version: x.y.z
        helm.sh/chart: trivy-operator-web-ui
      name: trivy-operator-web-ui-frontend
  6: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    metadata:
      labels:
        app.kubernetes.io/component: operator
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: trivy-operator-web-ui
        app.kubernetes.io/version: x.y.z
        helm.sh/chart: trivy-operator-web-ui
      name: trivy-operator-web-ui-operator
    rules:
      - apiGroups:
          - aquasecurity.github.io
        resources:
          - vulnerabilityreports
          - sbomreports
          - exposedsecretreports
        verbs:
          - get
          - watch
          - list
