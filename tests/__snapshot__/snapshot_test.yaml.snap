manifest should match snapshot:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/component: frontend
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: trivy-operator-web-ui-frontend
        helm.sh/chart: trivy-operator-web-ui-0.1.0
      name: trivy-operator-web-ui-frontend
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/component: frontend
          app.kubernetes.io/instance: RELEASE-NAME
          app.kubernetes.io/name: trivy-operator-web-ui-frontend
      template:
        metadata:
          annotations:
            annotations.pod.operator: "true"
          labels:
            app.kubernetes.io/component: frontend
            app.kubernetes.io/instance: RELEASE-NAME
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: trivy-operator-web-ui-frontend
            helm.sh/chart: trivy-operator-web-ui-0.1.0
            labels.pod.operator: "true"
        spec:
          affinity:
            nodeAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
                nodeSelectorTerms:
                  - matchExpressions:
                      - key: topology.kubernetes.io/frontend
                        operator: In
                        values:
                          - frontend-east1
                          - frontend-west1
          containers:
            - image: ghcr.io/trivy-operator-web-ui/frontend:1.0.0
              imagePullPolicy: IfNotPresent
              livenessProbe:
                httpGet:
                  path: /
                  port: http
              name: trivy-operator-web-ui-operator
              ports:
                - containerPort: 8080
                  name: http
                  protocol: TCP
              readinessProbe:
                httpGet:
                  path: /
                  port: http
              resources:
                limits:
                  memory: 100Mi
                requests:
                  cpu: 10m
          nodeSelector:
            disktype: ssdFrontend
          serviceAccountName: trivy-operator-web-ui-frontend
          tolerations:
            - effect: NoExecute
              key: node.kubernetes.io/frontend
              operator: Exists
              tolerationSeconds: 6000
  2: |
    apiVersion: networking.k8s.io/v1
    kind: Ingress
    metadata:
      annotations:
        kubernetes.io/tls-acme: "true"
      labels:
        app.kubernetes.io/component: frontend
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: trivy-operator-web-ui-frontend
        helm.sh/chart: trivy-operator-web-ui-0.1.0
      name: trivy-operator-web-ui-frontend
    spec:
      ingressClassName: frontendclassname
      rules:
        - host: frontend-1.com
          http:
            paths:
              - backend:
                  service:
                    name: trivy-operator-web-ui-frontend
                    port:
                      number: 8080
                path: /
                pathType: ImplementationSpecific
        - host: frontend-2.com
          http:
            paths:
              - backend:
                  service:
                    name: trivy-operator-web-ui-frontend
                    port:
                      number: 8080
                path: /
                pathType: ImplementationSpecific
        - host: frontend-3.com
          http:
            paths:
              - backend:
                  service:
                    name: trivy-operator-web-ui-frontend
                    port:
                      number: 8080
                path: /
                pathType: ImplementationSpecific
      tls:
        - hosts:
            - frontend-1.com
            - frontend-2.com
          secretName: frontend-1-2
        - hosts:
            - frontend-3.com
          secretName: frontend-3
  3: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app.kubernetes.io/component: frontend
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: trivy-operator-web-ui-frontend
        helm.sh/chart: trivy-operator-web-ui-0.1.0
      name: trivy-operator-web-ui-frontend
    spec:
      ports:
        - name: http
          port: 8080
          protocol: TCP
          targetPort: http
      selector:
        app.kubernetes.io/component: frontend
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/name: trivy-operator-web-ui-frontend
      type: ClusterIP
  4: |
